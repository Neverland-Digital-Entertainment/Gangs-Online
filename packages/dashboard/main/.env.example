# Firebase Configuration
# Get these values from your Firebase project settings
# https://console.firebase.google.com/

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Map Editor (optional): base URL of the static map GLB files.
# By default the dashboard serves maps same-origin at /maps — the
# predev/prebuild copy-maps script copies them from client/public/maps,
# so you do NOT need to set this. Only set it to load maps from an
# external origin (CORS must allow this dashboard's origin).
# NEXT_PUBLIC_MAP_BASE_URL=https://your-game-domain/maps

# Admin access: comma-separated list of admin emails allowed into the dashboard.
# Sign-in uses Firebase Auth (Google). If left empty, ANY signed-in Google
# account can access (a warning banner is shown) — set this for production.
# (Also enable Google sign-in in Firebase Console > Authentication.)
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com,other-admin@example.com

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the values with your actual Firebase configuration
# 3. Never commit .env.local to git (it's already in .gitignore)
# 4. For Cloudflare Pages, set these as Environment Variables in the Pages settings
