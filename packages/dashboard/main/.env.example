# Firebase Configuration
# Get these values from your Firebase project settings
# https://console.firebase.google.com/

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Map Editor: base URL of the static map GLB files (manifest.json + *.glb)
# Defaults to the local Vite client dev server. Point this at wherever the
# game's /maps folder is served (e.g. your Cloudflare Pages client URL).
NEXT_PUBLIC_MAP_BASE_URL=http://localhost:5173/maps

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the values with your actual Firebase configuration
# 3. Never commit .env.local to git (it's already in .gitignore)
# 4. For Cloudflare Pages, set these as Environment Variables in the Pages settings
